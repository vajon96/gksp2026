rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null 
        && request.auth.token.email_verified == true
        && (request.auth.token.email == "contact@ganaraj-ekta.org" || request.auth.token.email == "sajondey102@gmail.com" || request.auth.token.email.endsWith("@ganaraj-ekta.org"));
    }

    // Helper to check standard sign in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to validate document ID
    function isValidId(id) {
      return id.size() > 0 && id.size() < 100 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Main CMS Database state replicate document
    match /cms_database/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings collection
    match /settings/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Applications collection
    match /applications/{appId} {
      allow create: if isValidId(appId) 
        && request.resource.data.status == "pending"
        && request.resource.data.fullNameEnglish is string;
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email.toLowerCase() == resource.data.email.toLowerCase());
      allow update, delete: if isAdmin();
    }

    // Members collection
    match /members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notices collection
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events collection
    match /events/{eventId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['volunteers']));
    }

    // Donations collection
    match /donations/{donationId} {
      allow create: if isValidId(donationId) && request.resource.data.status == "pending";
      allow read, update, delete: if isAdmin();
    }

    // Custom Pages collection
    match /customPages/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics / logs
    match /analytics/visitors {
      allow read, write: if true;
    }
  }
}
